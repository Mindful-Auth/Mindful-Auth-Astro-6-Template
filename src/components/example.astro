---
// Example Astro component
interface Props {
  title?: string;
}

const { title = 'Welcome' } = Astro.props;
---

<div class="example-card">
  <h2>{title}</h2>
  <p>This is a simple Astro component example.</p>
  <button class="btn">Click me</button>
</div>

<style>
  .example-card {
    padding: 2rem;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    background: #f9f9f9;
  }

  h2 {
    margin-top: 0;
    color: #333;
  }

  .btn {
    padding: 0.5rem 1rem;
    background-color: #007bff;
    color: white;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 1rem;
  }

  .btn:hover {
    background-color: #0056b3;
  }
</style>
