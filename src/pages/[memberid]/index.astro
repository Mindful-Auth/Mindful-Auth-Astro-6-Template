---
import MAuthProtected from "@mindfulauth/astro/layouts/MAuthProtected.astro";
import ProtectedLayout from "@/layouts/ProtectedLayout.astro";
import { MAuthChangePassword, MAuthEnable2FA, MAuthDisable2FA, MAuthAddAuthMethod } from "@mindfulauth/astro/components";
---

<MAuthProtected title="Profile" scripts={['MAuthSecurityScript']}>
  <ProtectedLayout>
    <header>
      <h1>Profile Settings</h1>
    </header>

    <MAuthChangePassword
      class="content-card"
      formClass=""
      buttonClass="submit-btn"
      title="Change Password"
      submitLabel="Update Password"
    />

    <MAuthEnable2FA
      class="content-card"
      setupClass="content-card"
      qrWrapperClass="qr-wrapper"
      qrDisplayClass="qr-display"
      formClass="form-compact"
      buttonClass="submit-btn"
      recoveryCodesClass="content-card security-alert"
      recoveryListClass="recovery-list"
      recoveryCodesTitle="Save Your Recovery Codes"
      copyLabel="Copy Codes"
      title="Two-Factor Authentication"
      setupTitle="Scan the QR Code"
      enableLabel="Enable 2FA"
      verifyLabel="Verify & Enable"
    />

    <MAuthDisable2FA
      class="content-card security-alert alert-danger"
      formClass="form-compact"
      buttonClass="submit-btn btn-danger"
      title="Disable Two-Factor Authentication"
      submitLabel="Disable 2FA"
    />

    <MAuthAddAuthMethod
      class="content-card"
      buttonClass="submit-btn"
      title="Add Authentication Method"
      submitLabel="Add Authentication Method"
    />
  </ProtectedLayout>
</MAuthProtected>