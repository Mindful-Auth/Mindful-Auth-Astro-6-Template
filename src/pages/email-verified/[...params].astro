---
import MAuthPublic from "@mindfulauth/astro/layouts/MAuthPublic.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { MAuthMessage } from "@mindfulauth/astro/components";
---
<MAuthPublic title="Email Verified" scripts={['MAuthVerifyEmailScript']}>
<BaseLayout>
    <div class="auth-container">
        <div class="auth-card">
            <h1>Email Verification</h1>
            <MAuthMessage defaultText="Verifying your email..." />
            <a href="/login">Continue to Login</a>
        </div>
    </div>
</BaseLayout>
</MAuthPublic>