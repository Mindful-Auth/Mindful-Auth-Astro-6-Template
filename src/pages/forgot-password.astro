---
import MAuthPublic from "@mindfulauth/astro/layouts/MAuthPublic.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
    MAuthPasswordChangePending,
    MAuthForm,
    MAuthEmailInput,
    MAuthTurnstile,
    MAuthSubmitButton,
    MAuthMessage,
} from "@mindfulauth/astro/components";
---

<BaseLayout title="Forgot Password?">
    <MAuthPublic scripts={["MAuthTurnstileInit", "MAuthForgotPasswordScript"]}>
        <div class="auth-container">
            <div class="auth-card">
                <h1>Forgot Your Password?</h1>
                <p>
                    Enter your email address below, and we'll send you a link to
                    reset your password.
                </p>

                <MAuthPasswordChangePending />

                <MAuthForm formName="forgot-password">
                    <MAuthEmailInput />
                    <MAuthTurnstile />
                    <MAuthSubmitButton label="Send Reset Email" />
                    <MAuthMessage />
                </MAuthForm>

                <a href="/login"> Back to Login</a>
            </div>
        </div>
    </MAuthPublic>
</BaseLayout>
