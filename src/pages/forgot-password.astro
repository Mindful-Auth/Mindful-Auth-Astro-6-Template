---
// Forgot Password page
import MAuthPublic from "@/layouts/MAuthPublic.astro";
---

<MAuthPublic title="Forgot Password?" scripts={['MAuthTurnstileInit', 'MAuthForgotPasswordScript']}>
    <div class="auth-container">
        <div class="auth-card">
            <h1>Forgot Your Password?</h1>
            <p>
                Enter your email address below, and we'll send you a link to
                reset your password.
            </p>

            <div
                class="hidden"
                data-mindfulauth-field="password-change-pending"
            >
            </div>

            <form method="post" data-mindfulauth-form="forgot-password">
                <div>
                    <label>Email</label>
                    <input
                        type="email"
                        name="email"
                        required
                        data-mindfulauth-field="email"
                    />
                </div>
                <div data-mindfulauth-turnstile></div>
                <button type="submit">Send Reset Email</button>
                <p data-mindfulauth-field="message"></p>
            </form>

            <a href="/login">← Back to Login</a>
        </div>
    </div>
</MAuthPublic>