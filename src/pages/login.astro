---
import MAuthPublic from "@mindfulauth/astro/layouts/MAuthPublic.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
    MAuthForm,
    MAuthEmailInput,
    MAuthPasswordInput,
    MAuthTwoFASection,
    MAuthTurnstile,
    MAuthSubmitButton,
    MAuthMessage,
} from "@mindfulauth/astro/components";
---

<BaseLayout title="Sign In">
    <MAuthPublic scripts={["MAuthTurnstileInit", "MAuthLoginScript"]}>
        <div class="auth-container">
            <div class="auth-card">
                <h1>Sign In with Password</h1>
                <p>Enter your email and password to get started.</p>

                <MAuthForm formName="login">
                    <MAuthEmailInput />
                    <MAuthPasswordInput label="Password" />
                    <MAuthTwoFASection />
                    <a href="/forgot-password">Forgot Your Password?</a>
                    <MAuthTurnstile />
                    <MAuthSubmitButton label="Log In" />
                    <MAuthMessage />
                </MAuthForm>

                <div class="auth-links">
                    <a href="/magic-login">Sign In with Magic Link</a>
                    <a href="/register">Create an Account</a>
                </div>
            </div>
        </div>
    </MAuthPublic>
</BaseLayout>