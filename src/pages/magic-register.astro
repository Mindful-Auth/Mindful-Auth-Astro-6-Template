---
import MAuthPublic from "@mindfulauth/astro/layouts/MAuthPublic.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
    MAuthForm,
    MAuthNameInput,
    MAuthEmailInput,
    MAuthTurnstile,
    MAuthSubmitButton,
    MAuthMessage,
} from "@mindfulauth/astro/components";
---
<MAuthPublic title="Create Account with Magic Link" scripts={['MAuthTurnstileInit', 'MAuthMagicRegisterScript']}>
<BaseLayout>
    <div class="auth-container">
        <div class="auth-card">
            <h1>Create Your Account</h1>
            <p>Enter your details to get started with magic link authentication.</p>

            <MAuthForm formName="magic-register">
                <MAuthNameInput />
                <MAuthEmailInput />
                <MAuthTurnstile />
                <MAuthSubmitButton label="Create Account" />
                <MAuthMessage />
            </MAuthForm>

            <div class="auth-links">
                <a href="/magic-login">Already have an account? Sign In</a>
                <a href="/register">Register with Password</a>
            </div>
        </div>
    </div>
</BaseLayout>
</MAuthPublic>