---
import MAuthPublic from "@mindfulauth/astro/layouts/MAuthPublic.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
    MAuthForm,
    MAuthNameInput,
    MAuthEmailInput,
    MAuthPasswordInput,
    MAuthTurnstile,
    MAuthSubmitButton,
    MAuthMessage,
} from "@mindfulauth/astro/components";
---
<MAuthPublic title="Create Account" scripts={['MAuthTurnstileInit', 'MAuthRegisterPasswordScript']}>
<BaseLayout>
    <div class="auth-container">
        <div class="auth-card">
            <h1>Create New Account</h1>
            <p>Enter your name, email and password to get started.</p>

            <MAuthForm formName="register">
                <MAuthNameInput />
                <MAuthEmailInput />
                <MAuthPasswordInput label="Password" />
                <MAuthPasswordInput label="Confirm Password" fieldName="confirm-password" />
                <MAuthTurnstile />
                <MAuthMessage />
                <MAuthSubmitButton label="Create Account" />
            </MAuthForm>

            <div class="auth-links">
                <a href="/login">Already have an account? Sign In</a>
                <a href="/magic-register">Register with Magic Link</a>
            </div>
        </div>
    </div>
</BaseLayout>
</MAuthPublic>