---
import MAuthPublic from "@mindfulauth/astro/layouts/MAuthPublic.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
    MAuthForm,
    MAuthEmailInput,
    MAuthTurnstile,
    MAuthSubmitButton,
    MAuthMessage,
} from "@mindfulauth/astro/components";
---
<BaseLayout title="Resend Verification Email">
<MAuthPublic scripts={['MAuthTurnstileInit', 'MAuthResendVerificationScript']}>
    <div class="auth-container">
        <div class="auth-card">
            <h1>Resend Verification Email</h1>
            <p>Enter your email address below, and we'll send you a link to verify your email.</p>

            <MAuthForm formName="resend-verification">
                <MAuthEmailInput />
                <MAuthTurnstile />
                <MAuthSubmitButton label="Resend Verification Email" />
                <MAuthMessage />
            </MAuthForm>

            <a href="/login">&#8592; Back to Login</a>
        </div>
    </div>
</MAuthPublic>
</BaseLayout>