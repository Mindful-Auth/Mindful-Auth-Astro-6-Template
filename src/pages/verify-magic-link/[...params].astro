---
import MAuthPublic from "@mindfulauth/astro/layouts/MAuthPublic.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
    MAuthMessage,
    MAuthForm,
    MAuthTwoFACodeInput,
    MAuthTurnstile,
    MAuthSubmitButton,
} from "@mindfulauth/astro/components";
---
<MAuthPublic title="Verify Magic Link" scripts={['MAuthTurnstileInit', 'MAuthVerifyMagicLinkScript']}>
<BaseLayout>
    <div class="auth-container">
        <div class="auth-card">
            <h1>Verify Magic Link</h1>
            <MAuthMessage defaultText="Bot protection failed to load. Please refresh the page." />

            <MAuthForm formName="verify-magic-link">
                <MAuthTwoFACodeInput name="twofa-code-magic-link" label="Two-Factor Authentication Code" />
                <MAuthTurnstile />
                <MAuthSubmitButton label="Verify & Sign In" />
            </MAuthForm>

            <div id="footer-link">
                <a href="/magic-login">Request a new magic link</a>
            </div>
        </div>
    </div>
</BaseLayout>
</MAuthPublic>